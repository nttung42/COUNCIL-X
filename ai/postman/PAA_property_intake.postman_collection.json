        "body": {
          "mode": "raw",
          "raw": "{\n  \"input\": {\n    \"file_ids\": [\n      \"{{file_id_1}}\",\n      \"{{file_id_2}}\",\n      \"{{file_id_3}}\",\n      \"{{file_id_4}}\"\n    ],\n    \"case_id\": \"REQ-2026-0001\"\n  }\n}"
        },
