          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('registered', () => pm.response.to.have.status(201));",
              "const j = pm.response.json();",
              "if (j.api_key) {",
              "  pm.collectionVariables.set('api_key', j.api_key);",
              "  console.log('Saved api_key:', j.api_key);",
              "}"
            ]
