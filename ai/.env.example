# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/shb

# ============ LLM / Embedding (OpenAI-compatible via custom base_url) ============
# Do NOT commit real values. Never hardcode these in code — read from env only.

# Base URL of the OpenAI-compatible LLM gateway
LLM_BASE_URL=https://your-llm-gateway/api/v1
# API key for the gateway above
LLM_API_KEY=your-api-key
# Chat model id (e.g. cx/gpt-5.5)
LLM_MODEL=cx/gpt-5.5
# Optional vision model for OCR / scanned documents (leave empty to reuse LLM_MODEL)
LLM_VISION_MODEL=

# Inference Parameters
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_TOP_P=0.95

# Embeddings (dim must match EMBEDDING_MODEL: text-embedding-3-small = 1536)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536


# ============ Storage Configuration ============
STORAGE_DIR=storage
MAX_FILE_SIZE_MB=100

# ============ Document Parsing (hybrid PDF text/scan) ============
# Chars of extractable text per PDF page below which the page is treated as scanned.
PDF_SCAN_CHAR_THRESHOLD=50
# Fraction of scanned pages at/above which the whole PDF is treated as scanned.
PDF_SCAN_DOC_FRACTION=0.5
# DPI used when rasterizing scanned PDF pages to images for OCR / vision LLM.
PDF_RENDER_DPI=200

# ============ Celery Task Queue Configuration ============
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_LIMIT=3600
CELERY_TASK_HARD_LIMIT=3700
CELERY_TASK_MAX_RETRIES=3

# ============ Logging & Security ============
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-in-production
