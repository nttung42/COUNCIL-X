@startuml 01-agent-orchestration
title Kien truc dieu phoi Agent (Google ADK) - Tham dinh vay von doanh nghiep
skinparam componentStyle rectangle
skinparam backgroundColor #FFFFFF
skinparam component {
  BackgroundColor<<agent>> #E8F0FE
  BackgroundColor<<workflow>> #FFF3CD
  BackgroundColor<<human>> #FCE8E6
  BorderColor #4285F4
}

actor "RM / Chuyen vien QHKH" as RM
actor "Compliance Officer" as CO
actor "Credit Officer /\nHoi dong tin dung" as CredO

package "CreditAppraisalPipeline\n(SequentialAgent - root)" as ROOT <<workflow>> {

  component "Document Preprocessing\n(FunctionTool: ingest & extract)" as INTAKE

  package "AppraisalParallelStage\n(ParallelAgent)" as PARA <<workflow>> {
    component "LegalAgent\n(LlmAgent)" as LEGAL <<agent>>
    component "FinancialCreditAgent\n(LlmAgent)" as FIN <<agent>>
    component "CollateralAgent\n(LlmAgent)" as COL <<agent>>
  }

  component "ScoringAgent\n(LlmAgent)" as SCORE <<agent>>

  package "ComplianceRiskStage\n(SequentialAgent)" as COMP_STAGE <<workflow>> {
    component "ComplianceAMLAgent\n(LlmAgent)" as COMP <<agent>>
  }

  component "ReportingAgent\n(LlmAgent)" as REPORT <<agent>>
}

component "SessionService\n(state: legal_status, ratios,\ncollateral_value, score,\ncic_result, aml_flags, draft)" as SESSION
component "Omnirouter\n(self-hosted OpenAI-compatible\nLLM Gateway)" as ROUTER
component "Human AML Review Task\n(conditional gate)" as AML_GATE <<human>>
component "Human Approval Gate\n(ky duyet / phe duyet)" as APPROVE_GATE <<human>>

RM --> INTAKE : nop ho so vay
INTAKE --> PARA : ho so da cau truc hoa
PARA --> SCORE : legal_status + ratios + collateral_value
SCORE --> COMP_STAGE : credit_score + risk_tier
COMP --> AML_GATE : neu co match kha nghi
AML_GATE --> COMP : ket qua xac minh (clear/escalate)
COMP_STAGE --> REPORT : compliance_result
REPORT --> APPROVE_GATE : draft to trinh
APPROVE_GATE --> CredO : trinh ky
CO --> AML_GATE : xu ly canh bao

PARA ..> SESSION : read/write
PARA ..> ROUTER : LiteLlm client
SCORE ..> SESSION : read/write
SCORE ..> ROUTER : LiteLlm client
COMP_STAGE ..> SESSION : read/write
COMP_STAGE ..> ROUTER : LiteLlm client
REPORT ..> SESSION : read
REPORT ..> ROUTER : LiteLlm client

note right of ROUTER
  ADK: LlmAgent(model=LiteLlm(
    model="openai/<model-name>",
    api_base="https://omnirouter.internal/v1",
    api_key=<secret from Secrets Manager>
  ))
end note

note bottom of ROOT
  Ly do chon Sequential + Parallel:
  - Legal / Financial / Collateral doc lap du lieu -> chay song song de giam latency
  - Scoring can dau ra cua ca 3 -> phai cho xong Parallel Stage
  - Compliance/AML can biet related parties tu Legal + risk tier tu Scoring
    -> chay sau, tuan tu
  - Reporting la buoc tong hop cuoi -> luon chay sau cung
end note

@enduml
