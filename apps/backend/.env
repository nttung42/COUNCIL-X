# PAA backend — biến môi trường mẫu. Copy sang `.env` và điền giá trị thật.
# KHÔNG commit `.env` thật. KHÔNG hardcode các giá trị này trong code.

# --- LLM / Embedding (OpenAI-compatible qua custom base_url) ---
LLM_BASE_URL=https://omniroute.tunyen.com/api/v1
LLM_API_KEY=sk-2b5b775a412563dc-e8cd46-d938b33c
LLM_MODEL=cx/gpt-5.5
EMBEDDING_MODEL=text-embedding-3-small
# Số chiều vector của EMBEDDING_MODEL (text-embedding-3-small = 1536). Phải khớp
# model thật; đổi kèm khi đổi EMBEDDING_MODEL.
EMBEDDING_DIM=1536

# --- Database (PostgreSQL 16 + pgvector, driver sync psycopg v3) ---
DATABASE_URL=postgresql+psycopg://paa:paa@localhost:5432/paa
