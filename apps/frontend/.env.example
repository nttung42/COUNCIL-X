# Base URL of the ai/ backend (FastAPI, see ai/src/shb/main.py). Left unset by default —
# src/services/apiClient.ts falls back to local fixture data (src/mocks/fixtureCase.ts) when
# this is empty, so the UI keeps working with zero backend running.
#
# When ai/'s docker-compose is up (`docker compose up` from ai/), it publishes the API on host
# port 8888 (container 8000) — see ai/docker-compose.yml. Do NOT include the /api/v1 prefix here,
# apiClient.ts appends it itself.
#
# Only screen 1 (Nhập thông tin — document upload + property_intake extraction) is wired to the
# real API today; screens 2-5 + chat + edit-confirm still use fixture data because ai/ has no
# HTTP routes yet for lookup/valuation/risk/dashboard/chat/edit-log (only ORM models exist).
VITE_API_BASE_URL=http://localhost:8888
