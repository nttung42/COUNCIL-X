# Bật fixture mode: apiClient trả dữ liệu mock cục bộ, KHÔNG gọi backend thật.
# Dùng để phát triển/test UI độc lập khi Orchestrator & API chưa sẵn sàng.
# Khi tích hợp API thật ở bước cuối: đặt =false (hoặc xoá dòng này).
VITE_USE_FIXTURE=true

# URL backend thật khi VITE_USE_FIXTURE=false. apiClient gọi tương đối "/api/..."
# nên để trống sẽ dùng dev proxy trong vite.config.ts (mặc định http://localhost:8000).
# VITE_API_TARGET=http://localhost:8000
