@startuml 05-sequence-aml-exception
title Luong ngoai le - Canh bao AML/Sanction can con nguoi xac minh
autonumber

participant "CreditAppraisalPipeline" as ROOT
participant "ComplianceAMLAgent" as COMP
participant "sanctions_screening\n(Tool)" as TOOL
queue "SQS: aml-review-queue" as SQS
participant "SNS Notification" as SNS
actor "Compliance Officer" as CO
participant "SessionService" as SESSION

ROOT -> COMP : run(khach_hang_id, related_parties)
COMP -> TOOL : screen(names[])
TOOL -> TOOL : fuzzy match vs\nOFAC/UN/EU/PEP lists
TOOL --> COMP : match found\n(score=0.82, ten: "Nguyen Van A")

note right of COMP
  Theo quy dinh PCRT: agent KHONG duoc
  tu dong loai tru canh bao trung khop ten.
  Bat buoc phai chuyen cho con nguoi xac minh.
end note

COMP -> SESSION : write aml_flags (status=PENDING_REVIEW)
COMP -> SQS : enqueue review_task(match_details)
SQS -> SNS : notify
SNS -> CO : email/Slack: "Co canh bao AML can xac minh"

CO -> SQS : pick up task
CO -> CO : xac minh thu cong\n(doi chieu CCCD, ngay sinh,\nnguon goc thong tin...)

alt Xac dinh false positive
  CO -> SESSION : update aml_flags (status=CLEARED, note)
  CO -> ROOT : resume pipeline
  ROOT -> COMP : tiep tuc (compliance_result = clear)
else Xac dinh match that (true positive)
  CO -> SESSION : update aml_flags (status=CONFIRMED_MATCH)
  CO -> ROOT : halt pipeline - tu choi ho so
  ROOT -> ROOT : dung, ghi log ly do tu choi
end

@enduml
